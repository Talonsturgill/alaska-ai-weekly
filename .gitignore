out/
__pycache__/
*.pyc
.DS_Store
.venv/
.venv-voice/
.env
# fonts are committed (OFL-licensed) so routine clones don't re-download them
# dispatch_core.py reads/writes timing+caption-textlog scratch relative to its OWN dir,
# not out/dispatch/, so per-run audio/textlog artifacts land here too. Never commit them.
.claude/skills/alaska-dispatch/audio/
.claude/skills/alaska-dispatch/textlog/
.claude/skills/alaska-dispatch/quality_report.json
.claude/skills/alaska-dispatch/frames_*/
.claude/skills/alaska-dispatch/test_*/
.claude/skills/alaska-dispatch/*.mp4

# dimensional engine render outputs (intermediates, never commit — like out/)
.claude/skills/alaska-dispatch/demo3d_frames/
.claude/skills/alaska-dispatch/frames_v3/
.claude/skills/alaska-dispatch/textlog/
.claude/skills/alaska-dispatch/*.mp4
.claude/skills/alaska-dispatch/__pycache__/
**/__pycache__/

# per-run dimensional render frames + logs (heavy, rebuildable, never commit)
.claude/skills/alaska-dispatch/lookdev_gt/
.claude/skills/alaska-dispatch/groundstwin_frames/
.claude/skills/alaska-dispatch/thelid_final/
.claude/skills/alaska-dispatch/archive_final/
.claude/skills/alaska-dispatch/archive_frames/
.claude/skills/alaska-dispatch/permafrost_frames/
.claude/skills/alaska-dispatch/lookdev/
.claude/skills/alaska-dispatch/*.log
.claude/skills/alaska-dispatch/frames_v3
.claude/skills/alaska-dispatch/shots.json
.claude/skills/alaska-dispatch/render_manifest.json
