#!/usr/bin/env bash
# AUTO-PUSH GUARDRAIL (permanent fix, 2026-07-21).
# WHY THIS EXISTS: this routine runs in an EPHEMERAL container that is reclaimed after
# periods of low activity. On 2026-07-21 a Dispatch run committed its work LOCALLY but
# never pushed; the container was reclaimed mid-run and re-cloned fresh, destroying every
# unpushed commit (a fully-built, gate-passed video). Committing is not durable here —
# only origin is. So EVERY commit auto-mirrors to origin immediately. A reclamation can
# now cost at most the current in-flight render, never authored/committed code again.
#
# Safe by construction: never pushes main/master (protects the shared branch); pushes in
# the BACKGROUND so commits stay fast; never fails the commit (always exits 0); pushing
# does not itself create a commit, so there is no hook loop.
set -uo pipefail
branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
case "$branch" in
  ""|"HEAD"|"main"|"master") exit 0 ;;   # detached or protected branch: do nothing
esac
log=".git/auto-push.log"
(
  for attempt in 1 2 3 4; do
    if git push -u origin "$branch" >>"$log" 2>&1; then
      echo "$(git rev-parse --short HEAD) auto-pushed to origin/$branch (try $attempt)" >>"$log"
      exit 0
    fi
    sleep $((attempt * attempt))   # 1s, 4s, 9s, 16s backoff for transient network
  done
  echo "WARN auto-push FAILED for $branch after 4 tries — push manually" >>"$log"
) >/dev/null 2>&1 &
exit 0
