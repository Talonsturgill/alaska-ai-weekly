{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Task",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "mcp__Gmail",
      "mcp__github"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "pip install -q -r requirements.txt" }
        ]
      }
    ]
  }
}
