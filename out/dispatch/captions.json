[
  {
    "text": "Alaska is about to give away",
    "start": 0.0,
    "end": 1.82,
    "seg": 0
  },
  {
    "text": "thirty one square miles of land.",
    "start": 1.82,
    "end": 3.62,
    "seg": 0
  },
  {
    "text": "For free.",
    "start": 4.14,
    "end": 4.98,
    "seg": 1
  },
  {
    "text": "To a state agency called AIDEA.",
    "start": 5.42,
    "end": 7.3,
    "seg": 1
  },
  {
    "text": "It's birch forest near Houston.",
    "start": 9.8,
    "end": 10.375,
    "seg": 2
  },
  {
    "text": "More than forty miles of mushing trails.",
    "start": 10.375,
    "end": 11.18,
    "seg": 2
  },
  {
    "text": "The plan: data centers.",
    "start": 15.02,
    "end": 16.82,
    "seg": 3
  },
  {
    "text": "A rail hub.",
    "start": 17.44,
    "end": 18.18,
    "seg": 3
  },
  {
    "text": "Power lines.",
    "start": 18.56,
    "end": 19.2,
    "seg": 3
  },
  {
    "text": "No company has signed on yet.",
    "start": 20.04,
    "end": 21.88,
    "seg": 4
  },
  {
    "text": "Houston's town council tried to",
    "start": 22.58,
    "end": 24.54,
    "seg": 5
  },
  {
    "text": "ban it.",
    "start": 24.5,
    "end": 24.54,
    "seg": 5
  },
  {
    "text": "But their line falls two miles short.",
    "start": 27.46,
    "end": 28.18,
    "seg": 6
  },
  {
    "text": "It never reaches this land.",
    "start": 29.1,
    "end": 30.8,
    "seg": 7
  },
  {
    "text": "AIDEA says it straight: no decisions",
    "start": 32.5,
    "end": 35.48,
    "seg": 8
  },
  {
    "text": "have been made.",
    "start": 35.48,
    "end": 36.38,
    "seg": 8
  },
  {
    "text": "Comments close August nineteenth.",
    "start": 37.22,
    "end": 39.42,
    "seg": 9
  },
  {
    "text": "Nothing here is final.",
    "start": 39.42,
    "end": 40.8,
    "seg": 9
  },
  {
    "text": "So the fence stands empty.",
    "start": 41.72,
    "end": 43.26,
    "seg": 10
  },
  {
    "text": "The shadow keeps reaching.",
    "start": 43.76,
    "end": 44.84,
    "seg": 10
  },
  {
    "text": "The dogs still run this trail",
    "start": 45.78,
    "end": 47.18,
    "seg": 11
  },
  {
    "text": "either way.",
    "start": 47.18,
    "end": 47.68,
    "seg": 11
  },
  {
    "text": "Nobody's said yes here.",
    "start": 49.54,
    "end": 50.92,
    "seg": 12
  },
  {
    "text": "Nobody's said no where it counts.",
    "start": 51.2,
    "end": 53.4,
    "seg": 12
  }
]