[
  {
    "text": "Alaska is about to give away",
    "start": 0.0,
    "end": 1.72,
    "seg": 0
  },
  {
    "text": "thirty one square miles of land.",
    "start": 1.76,
    "end": 3.96,
    "seg": 0
  },
  {
    "text": "For free.",
    "start": 4.499,
    "end": 5.299,
    "seg": 1
  },
  {
    "text": "To a state agency called AIDEA.",
    "start": 5.519,
    "end": 7.699,
    "seg": 1
  },
  {
    "text": "It's birch forest near Houston.",
    "start": 8.126,
    "end": 9.966,
    "seg": 2
  },
  {
    "text": "More than forty miles of mushing trails.",
    "start": 10.486,
    "end": 12.546,
    "seg": 2
  },
  {
    "text": "The plan: data centers.",
    "start": 13.213,
    "end": 14.973,
    "seg": 3
  },
  {
    "text": "A rail hub.",
    "start": 15.393,
    "end": 16.373,
    "seg": 3
  },
  {
    "text": "Power lines.",
    "start": 16.913,
    "end": 17.713,
    "seg": 3
  },
  {
    "text": "No company has signed on yet.",
    "start": 18.22,
    "end": 19.98,
    "seg": 4
  },
  {
    "text": "Houston's town council tried to",
    "start": 20.485,
    "end": 22.525,
    "seg": 5
  },
  {
    "text": "ban it.",
    "start": 22.565,
    "end": 23.301,
    "seg": 5
  },
  {
    "text": "But their line falls two miles short.",
    "start": 23.341,
    "end": 25.661,
    "seg": 6
  },
  {
    "text": "It never reaches this land.",
    "start": 26.205,
    "end": 27.705,
    "seg": 7
  },
  {
    "text": "AIDEA says it straight: no decisions",
    "start": 28.321,
    "end": 31.101,
    "seg": 8
  },
  {
    "text": "have been made.",
    "start": 31.141,
    "end": 32.141,
    "seg": 8
  },
  {
    "text": "Comments close August nineteenth.",
    "start": 32.654,
    "end": 34.534,
    "seg": 9
  },
  {
    "text": "Nothing here is final.",
    "start": 34.854,
    "end": 36.174,
    "seg": 9
  },
  {
    "text": "So the fence stands empty.",
    "start": 36.718,
    "end": 38.658,
    "seg": 10
  },
  {
    "text": "The shadow keeps reaching.",
    "start": 38.698,
    "end": 40.818,
    "seg": 10
  },
  {
    "text": "The dogs still run this trail",
    "start": 41.438,
    "end": 43.158,
    "seg": 11
  },
  {
    "text": "either way.",
    "start": 43.198,
    "end": 43.998,
    "seg": 11
  },
  {
    "text": "Nobody's said yes here.",
    "start": 45.405,
    "end": 46.765,
    "seg": 12
  },
  {
    "text": "Nobody's said no where it counts.",
    "start": 47.585,
    "end": 49.225,
    "seg": 12
  }
]