[
  {
    "text": "Alaska is about to give away",
    "start": 0.0,
    "end": 1.34,
    "seg": 0
  },
  {
    "text": "thirty one square miles of land.",
    "start": 1.34,
    "end": 3.46,
    "seg": 0
  },
  {
    "text": "For free.",
    "start": 4.26,
    "end": 4.3,
    "seg": 1
  },
  {
    "text": "To a state agency called AIDEA.",
    "start": 4.26,
    "end": 8.78,
    "seg": 1
  },
  {
    "text": "It's birch forest near Houston.",
    "start": 9.92,
    "end": 11.76,
    "seg": 2
  },
  {
    "text": "More than forty miles of mushing trails.",
    "start": 12.14,
    "end": 14.38,
    "seg": 2
  },
  {
    "text": "The plan: data centers.",
    "start": 15.14,
    "end": 16.88,
    "seg": 3
  },
  {
    "text": "A rail hub.",
    "start": 17.44,
    "end": 18.28,
    "seg": 3
  },
  {
    "text": "Power lines.",
    "start": 18.76,
    "end": 19.32,
    "seg": 3
  },
  {
    "text": "No company has signed on yet.",
    "start": 20.16,
    "end": 22.0,
    "seg": 4
  },
  {
    "text": "Houston's town council tried to",
    "start": 22.7,
    "end": 25.1,
    "seg": 5
  },
  {
    "text": "ban it.",
    "start": 25.1,
    "end": 25.6,
    "seg": 5
  },
  {
    "text": "But their line falls two miles short.",
    "start": 26.24,
    "end": 28.5,
    "seg": 6
  },
  {
    "text": "It never reaches this land.",
    "start": 29.22,
    "end": 30.92,
    "seg": 7
  },
  {
    "text": "AIDEA says it straight: no decisions",
    "start": 32.9,
    "end": 35.64,
    "seg": 8
  },
  {
    "text": "have been made.",
    "start": 35.64,
    "end": 36.52,
    "seg": 8
  },
  {
    "text": "Comments close August nineteenth.",
    "start": 37.34,
    "end": 39.54,
    "seg": 9
  },
  {
    "text": "Nothing here is final.",
    "start": 39.54,
    "end": 40.92,
    "seg": 9
  },
  {
    "text": "So the fence stands empty.",
    "start": 41.84,
    "end": 43.4,
    "seg": 10
  },
  {
    "text": "The shadow keeps reaching.",
    "start": 43.84,
    "end": 44.88,
    "seg": 10
  },
  {
    "text": "The dogs still run this trail",
    "start": 45.9,
    "end": 47.3,
    "seg": 11
  },
  {
    "text": "either way.",
    "start": 47.3,
    "end": 47.8,
    "seg": 11
  },
  {
    "text": "Nobody's said yes here.",
    "start": 48.56,
    "end": 49.94,
    "seg": 12
  },
  {
    "text": "Nobody's said no where it counts.",
    "start": 50.2,
    "end": 52.42,
    "seg": 12
  }
]