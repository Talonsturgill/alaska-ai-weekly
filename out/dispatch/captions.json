[
  {
    "text": "Alaska is about to give away",
    "start": 0.0,
    "end": 2.285,
    "seg": 0
  },
  {
    "text": "thirty one square miles of land.",
    "start": 2.285,
    "end": 3.76,
    "seg": 0
  },
  {
    "text": "For free.",
    "start": 4.26,
    "end": 5.335,
    "seg": 1
  },
  {
    "text": "To a state agency called AIDEA.",
    "start": 5.335,
    "end": 8.56,
    "seg": 1
  },
  {
    "text": "It's birch forest near Houston.",
    "start": 9.92,
    "end": 11.67,
    "seg": 2
  },
  {
    "text": "More than forty miles of mushing trails.",
    "start": 11.67,
    "end": 14.12,
    "seg": 2
  },
  {
    "text": "The plan: data centers.",
    "start": 15.14,
    "end": 15.984,
    "seg": 3
  },
  {
    "text": "A rail hub.",
    "start": 15.984,
    "end": 16.618,
    "seg": 3
  },
  {
    "text": "Power lines.",
    "start": 16.618,
    "end": 17.04,
    "seg": 3
  },
  {
    "text": "No company has signed on yet.",
    "start": 20.16,
    "end": 22.2,
    "seg": 4
  },
  {
    "text": "Houston's town council tried to",
    "start": 22.7,
    "end": 24.314,
    "seg": 5
  },
  {
    "text": "ban it.",
    "start": 24.314,
    "end": 24.96,
    "seg": 5
  },
  {
    "text": "But their line falls two miles short.",
    "start": 26.24,
    "end": 27.94,
    "seg": 6
  },
  {
    "text": "It never reaches this land.",
    "start": 30.42,
    "end": 31.22,
    "seg": 7
  },
  {
    "text": "AIDEA says it straight: no decisions",
    "start": 31.72,
    "end": 34.107,
    "seg": 8
  },
  {
    "text": "have been made.",
    "start": 34.107,
    "end": 35.3,
    "seg": 8
  },
  {
    "text": "Comments close August nineteenth.",
    "start": 37.34,
    "end": 38.92,
    "seg": 9
  },
  {
    "text": "Nothing here is final.",
    "start": 38.92,
    "end": 40.5,
    "seg": 9
  },
  {
    "text": "So the fence stands empty.",
    "start": 41.84,
    "end": 42.711,
    "seg": 10
  },
  {
    "text": "The shadow keeps reaching.",
    "start": 42.711,
    "end": 43.74,
    "seg": 10
  },
  {
    "text": "The dogs still run this trail",
    "start": 45.9,
    "end": 48.06,
    "seg": 11
  },
  {
    "text": "either way.",
    "start": 48.06,
    "end": 48.06,
    "seg": 11
  },
  {
    "text": "Nobody's said yes here.",
    "start": 49.66,
    "end": 51.04,
    "seg": 12
  },
  {
    "text": "Nobody's said no where it counts.",
    "start": 51.34,
    "end": 53.52,
    "seg": 12
  }
]