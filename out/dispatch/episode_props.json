{"captions": [{"text": "Alaska is about to give away", "start": 0.0, "end": 1.46, "seg": 0}, {"text": "thirty one square miles of land.", "start": 1.46, "end": 3.44, "seg": 0}, {"text": "For free.", "start": 4.14, "end": 4.96, "seg": 1}, {"text": "To a state agency called AIDEA.", "start": 5.3, "end": 8.82, "seg": 1}, {"text": "It's birch forest near Houston.", "start": 11.14, "end": 11.18, "seg": 2}, {"text": "More than forty miles of mushing trails.", "start": 11.14, "end": 14.3, "seg": 2}, {"text": "The plan: data centers.", "start": 15.02, "end": 16.76, "seg": 3}, {"text": "A rail hub.", "start": 17.22, "end": 18.14, "seg": 3}, {"text": "Power lines.", "start": 18.56, "end": 19.22, "seg": 3}, {"text": "No company has signed on yet.", "start": 20.04, "end": 21.88, "seg": 4}, {"text": "Houston's town council tried to", "start": 22.58, "end": 25.0, "seg": 5}, {"text": "ban it.", "start": 25.0, "end": 25.48, "seg": 5}, {"text": "But their line falls two miles short.", "start": 26.12, "end": 28.38, "seg": 6}, {"text": "It never reaches this land.", "start": 29.1, "end": 30.8, "seg": 7}, {"text": "AIDEA says it straight: no decisions", "start": 32.86, "end": 35.5, "seg": 8}, {"text": "have been made.", "start": 35.5, "end": 36.4, "seg": 8}, {"text": "Comments close August nineteenth.", "start": 37.22, "end": 39.42, "seg": 9}, {"text": "Nothing here is final.", "start": 39.42, "end": 40.8, "seg": 9}, {"text": "So the fence stands empty.", "start": 41.72, "end": 43.28, "seg": 10}, {"text": "The shadow keeps reaching.", "start": 43.76, "end": 44.86, "seg": 10}, {"text": "The dogs still run this trail", "start": 45.78, "end": 47.18, "seg": 11}, {"text": "either way.", "start": 47.18, "end": 47.68, "seg": 11}, {"text": "Nobody's said yes here.", "start": 49.54, "end": 50.92, "seg": 12}, {"text": "Nobody's said no where it counts.", "start": 51.2, "end": 53.4, "seg": 12}], "scenes": [{"from": 0, "dur": 294}, {"from": 294, "dur": 307}, {"from": 601, "dur": 183}, {"from": 784, "dur": 164}, {"from": 948, "dur": 304}, {"from": 1252, "dur": 378}], "total": 1630}