{"captions": [{"text": "A machine got hungry.", "start": 0.0, "end": 0.92, "seg": 0}, {"text": "And it looked at Alaska.", "start": 1.3, "end": 2.2, "seg": 0}, {"text": "It wants a square mile of", "start": 3.2, "end": 4.52, "seg": 1}, {"text": "the North Slope near Deadhorse.", "start": 4.52, "end": 6.08, "seg": 1}, {"text": "Plus a gigawatt of gas power", "start": 6.6, "end": 8.48, "seg": 1}, {"text": "to feed itself.", "start": 8.48, "end": 9.28, "seg": 1}, {"text": "One building.", "start": 10.31, "end": 10.97, "seg": 2}, {"text": "About thirty percent more electricity", "start": 11.45, "end": 13.21, "seg": 2}, {"text": "than every city in Alaska, combined.", "start": 13.21, "end": 16.11, "seg": 2}, {"text": "The cost, by the company's own math?", "start": 17.16, "end": 19.1, "seg": 3}, {"text": "Five hundred million dollars.", "start": 19.6, "end": 20.66, "seg": 3}, {"text": "Or over ten billion.", "start": 21.2, "end": 22.24, "seg": 3}, {"text": "A twenty times guess.", "start": 22.72, "end": 23.54, "seg": 3}, {"text": "So Alaskans grabbed a pen.", "start": 24.63, "end": 25.97, "seg": 4}, {"text": "Over five hundred comments.", "start": 26.41, "end": 27.41, "seg": 4}, {"text": "Fewer than a dozen said yes.", "start": 28.03, "end": 29.33, "seg": 4}, {"text": "Some kept it short.", "start": 30.35, "end": 31.09, "seg": 5}, {"text": "Here's the honest part.", "start": 34.67, "end": 35.55, "seg": 6}, {"text": "Nothing is built.", "start": 36.03, "end": 36.69, "seg": 6}, {"text": "No customers.", "start": 37.21, "end": 37.71, "seg": 6}, {"text": "No computer chips.", "start": 38.31, "end": 39.15, "seg": 6}, {"text": "And the state has not decided.", "start": 39.71, "end": 41.09, "seg": 6}, {"text": "The comment window is the real vote.", "start": 42.02, "end": 43.92, "seg": 7}, {"text": "And it closes tomorrow.", "start": 44.44, "end": 45.46, "seg": 7}, {"text": "July seventeenth.", "start": 45.92, "end": 46.88, "seg": 7}, {"text": "So the loudest thing on the", "start": 47.64, "end": 48.62, "seg": 8}, {"text": "tundra is not the machine.", "start": 48.62, "end": 50.18, "seg": 8}, {"text": "It's the mailbox.", "start": 50.66, "end": 51.16, "seg": 8}, {"text": "What would your comment say?", "start": 51.84, "end": 52.72, "seg": 8}], "scenes": [{"from": 0, "dur": 309}, {"from": 309, "dur": 206}, {"from": 515, "dur": 224}, {"from": 739, "dur": 171}, {"from": 910, "dur": 130}, {"from": 1040, "dur": 221}, {"from": 1261, "dur": 168}, {"from": 1429, "dur": 244}], "total": 1673}