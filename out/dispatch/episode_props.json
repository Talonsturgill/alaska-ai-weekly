{"captions": [{"text": "Alaska is about to give away", "start": 0.0, "end": 2.3, "seg": 0}, {"text": "thirty one square miles of land.", "start": 2.34, "end": 4.88, "seg": 0}, {"text": "For free.", "start": 5.751, "end": 6.711, "seg": 1}, {"text": "To a state agency called AIDEA.", "start": 7.171, "end": 9.711, "seg": 1}, {"text": "It's birch forest near Houston.", "start": 10.542, "end": 12.922, "seg": 2}, {"text": "More than forty miles of mushing trails.", "start": 13.562, "end": 15.922, "seg": 2}, {"text": "The plan: data centers.", "start": 16.973, "end": 19.193, "seg": 3}, {"text": "A rail hub.", "start": 19.893, "end": 20.833, "seg": 3}, {"text": "Power lines.", "start": 21.473, "end": 22.273, "seg": 3}, {"text": "No company has signed on yet.", "start": 23.364, "end": 25.744, "seg": 4}, {"text": "Houston's town council tried to", "start": 26.635, "end": 29.315, "seg": 5}, {"text": "ban it.", "start": 29.355, "end": 30.155, "seg": 5}, {"text": "But their line falls two miles short.", "start": 30.546, "end": 33.526, "seg": 6}, {"text": "It never reaches this land.", "start": 34.537, "end": 36.577, "seg": 7}, {"text": "AIDEA says it straight: no decisions", "start": 37.568, "end": 41.168, "seg": 8}, {"text": "have been made.", "start": 41.208, "end": 42.408, "seg": 8}, {"text": "Comments close August nineteenth.", "start": 43.319, "end": 45.779, "seg": 9}, {"text": "Nothing here is final.", "start": 46.299, "end": 47.659, "seg": 9}, {"text": "So the fence stands empty.", "start": 48.63, "end": 51.17, "seg": 10}, {"text": "The shadow keeps reaching.", "start": 51.97, "end": 53.65, "seg": 10}, {"text": "The dogs still run this trail", "start": 54.741, "end": 57.061, "seg": 11}, {"text": "either way.", "start": 57.101, "end": 57.901, "seg": 11}, {"text": "Nobody's said yes here.", "start": 59.672, "end": 61.592, "seg": 12}, {"text": "Nobody's said no where it counts.", "start": 62.452, "end": 64.152, "seg": 12}], "scenes": [{"from": 0, "dur": 316}, {"from": 316, "dur": 385}, {"from": 701, "dur": 215}, {"from": 916, "dur": 211}, {"from": 1127, "dur": 332}, {"from": 1459, "dur": 567}], "total": 2026}