{"captions": [{"text": "A machine got hungry.", "start": 0.0, "end": 0.92, "seg": 0}, {"text": "And it looked at Alaska.", "start": 1.3, "end": 2.22, "seg": 0}, {"text": "It wants a square mile of", "start": 3.2, "end": 4.52, "seg": 1}, {"text": "the North Slope near Deadhorse.", "start": 4.52, "end": 6.08, "seg": 1}, {"text": "Plus a gigawatt of gas power", "start": 6.6, "end": 8.48, "seg": 1}, {"text": "to feed itself.", "start": 8.48, "end": 9.3, "seg": 1}, {"text": "One building.", "start": 10.31, "end": 10.97, "seg": 2}, {"text": "About thirty percent more electricity", "start": 11.45, "end": 13.07, "seg": 2}, {"text": "than every city in Alaska, combined.", "start": 13.07, "end": 16.13, "seg": 2}, {"text": "The cost, by the company's own math?", "start": 17.16, "end": 19.1, "seg": 3}, {"text": "Five hundred million dollars.", "start": 19.66, "end": 20.66, "seg": 3}, {"text": "Or over ten billion.", "start": 21.24, "end": 22.24, "seg": 3}, {"text": "A twenty times guess.", "start": 22.72, "end": 23.54, "seg": 3}, {"text": "So Alaskans grabbed a pen.", "start": 24.63, "end": 25.97, "seg": 4}, {"text": "Over five hundred comments.", "start": 26.41, "end": 27.41, "seg": 4}, {"text": "Fewer than a dozen said yes.", "start": 28.03, "end": 29.33, "seg": 4}, {"text": "Some kept it short.", "start": 30.35, "end": 31.17, "seg": 5}, {"text": "Quote: hell no.", "start": 31.75, "end": 32.79, "seg": 5}, {"text": "Quote: no A.I.", "start": 33.21, "end": 34.09, "seg": 5}, {"text": "Here's the honest part.", "start": 34.92, "end": 35.78, "seg": 6}, {"text": "Nothing is built.", "start": 36.28, "end": 36.86, "seg": 6}, {"text": "No customers.", "start": 37.36, "end": 37.9, "seg": 6}, {"text": "No chips.", "start": 38.54, "end": 38.94, "seg": 6}, {"text": "The state has not decided.", "start": 39.58, "end": 40.72, "seg": 6}, {"text": "The comment window is the real vote.", "start": 41.62, "end": 43.5, "seg": 7}, {"text": "And it closes tomorrow.", "start": 43.92, "end": 45.04, "seg": 7}, {"text": "July seventeenth.", "start": 45.42, "end": 46.5, "seg": 7}, {"text": "So the loudest thing on the", "start": 47.24, "end": 48.22, "seg": 8}, {"text": "tundra is not the machine.", "start": 48.22, "end": 49.78, "seg": 8}, {"text": "It's the mailbox.", "start": 50.26, "end": 50.76, "seg": 8}, {"text": "What would your comment say?", "start": 51.44, "end": 52.32, "seg": 8}]}